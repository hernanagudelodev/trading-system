{
    "_version": "etf_v1",
    "_description": "ETF scoring profile — removes fundamentals (pe, eps_growth, debt_equity, profit_margin), redistributes weight to technical and volatility criteria",
    "_date": "2026-05-14",
    "_rationale": [
        "ETFs have no earnings, PE ratio, EPS growth, or profit margin",
        "Fundamental criteria always return 0 for ETFs → artificially low scores",
        "Technical and volatility criteria work well for ETFs",
        "Earnings criterion set to always return SAFE (ETFs have no earnings risk)",
        "PCR and OI weighted positively — ETFs have much better options liquidity than individual stocks",
        "IV percentile and iv_vs_hv remain key criteria — ETF options are liquid and well-priced"
    ],
    "_backtest_results": {
        "viable_signals": null,
        "viable_pct": null,
        "viable_win_rate": null,
        "avg_return_pct": null,
        "notes": "Pending backtest validation"
    },

    "thresholds": {
        "viable": 0.60,
        "caution": 0.35
    },

    "score_max": 22,

    "trend_25d": {
        "bullish":  2,
        "bearish": -2
    },

    "moving_averages": {
        "above_both":  3,
        "above_sma50": 1,
        "below_both": -2
    },

    "sma50_direction": {
        "rising":   2,
        "flat":     0,
        "falling": -2
    },

    "rsi": {
        "overbought":   70,
        "oversold":     30,
        "neutral_low":  40,
        "neutral_high": 60,
        "score_neutral":  2,
        "score_caution":  1,
        "score_extreme": -1
    },

    "hv": {
        "low_threshold":  20,
        "high_threshold": 40,
        "score_low":    2,
        "score_normal": 1,
        "score_high":  -1
    },

    "iv_vs_hv": {
        "normal_threshold": 1.3,
        "score_cheap":     2,
        "score_normal":    1,
        "score_expensive": -2
    },

    "iv_percentile": {
        "cheap":        25,
        "normal_low":   50,
        "normal_high":  75,
        "score_cheap":       3,
        "score_normal_low":  2,
        "score_normal_high": 0,
        "score_expensive":  -2
    },

    "beta": {
        "high_threshold": 1.5,
        "low_threshold":  0.8,
        "score_normal":  1,
        "score_low":     0,
        "score_high":   -1
    },

    "put_call_ratio": {
        "fear_threshold": 1.3,
        "neutral_low":    0.7,
        "optimism":       0.5,
        "score_fear":     1,
        "score_neutral":  1,
        "score_optimism": 0,
        "score_euphoria":-1
    },

    "open_interest": {
        "high_threshold": 50000,
        "low_threshold":  5000,
        "score_high":   1,
        "score_normal": 0,
        "score_low":   -1
    },

    "week_52": {
        "score_near_low":  1,
        "score_mid":       1,
        "score_near_high": -1
    },

    "support_resistance": {
        "near_threshold_pct":    3.0,
        "score_near_support":    2,
        "score_middle":          1,
        "score_near_resistance": -1,
        "score_no_data":         0
    },

    "candlestick": {
        "score_strong_bullish":  2,
        "score_weak_bullish":    1,
        "score_neutral":         0,
        "score_weak_bearish":   -1,
        "score_strong_bearish": -2
    },

    "earnings": {
        "danger_days":       0,
        "caution_days":      0,
        "score_safe":        1,
        "score_caution":     1,
        "score_danger":      1
    },

    "volume": {
        "high_threshold": 1.5,
        "low_threshold":  0.5,
        "score_high":   1,
        "score_normal": 1,
        "score_low":   -1
    },

    "pe": {
        "cheap_threshold":     15,
        "normal_threshold":    25,
        "expensive_threshold": 40,
        "score_cheap":       0,
        "score_normal":      0,
        "score_expensive":   0,
        "score_very_expensive": 0
    },

    "eps_growth": {
        "strong_threshold":  15,
        "decline_threshold": -10,
        "score_strong":       0,
        "score_stable":       0,
        "score_declining":    0,
        "score_deteriorating": 0
    },

    "debt_equity": {
        "low_threshold":  1.0,
        "high_threshold": 2.0,
        "score_low":      0,
        "score_moderate": 0,
        "score_high":     0
    },

    "profit_margin": {
        "high_threshold":   20,
        "normal_threshold": 10,
        "score_high":      0,
        "score_normal":    0,
        "score_low":       0,
        "score_negative":  0
    }
}